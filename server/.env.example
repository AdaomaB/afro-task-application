# ============================================================
# Afro Task - Backend Environment Variables
# Copy this file to .env and fill in your real values.
# NEVER commit .env to GitHub.
# ============================================================

# Server
PORT=3001
NODE_ENV=production

# Frontend URL (used for CORS)
# Set this to your live frontend domain on Hostinger
FRONTEND_URL=https://afrotask.digify.com.ng

# JWT Secret - generate a strong random string
# Example: openssl rand -base64 64
JWT_SECRET=YOUR_GENERATED_SECRET_HERE

# ============================================================
# Firebase Admin SDK
# Option A (Recommended for Hostinger): Base64-encoded credentials
# Run: base64 -i serviceAccountKey.json | tr -d '\n'
# Then paste the output as FIREBASE_BASE64_CREDENTIALS
# ============================================================
FIREBASE_BASE64_CREDENTIALS=YOUR_BASE64_STRING_HERE

# Option B: Individual fields (use if Base64 doesn't work)
# FIREBASE_PROJECT_ID=my-p-2456
# FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@my-p-2456.iam.gserviceaccount.com
# FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_KEY\n-----END PRIVATE KEY-----\n"

FIREBASE_STORAGE_BUCKET=my-p-2456.appspot.com

# ============================================================
# Cloudinary - Image uploads
# Get these from https://cloudinary.com/console
# ============================================================
CLOUDINARY_CLOUD_NAME=YOUR_CLOUD_NAME
CLOUDINARY_API_KEY=YOUR_API_KEY
CLOUDINARY_API_SECRET=YOUR_API_SECRET

# ============================================================
# Email / SMTP (optional - for contact form notifications)
# Use a Gmail App Password (not your real password)
# https://myaccount.google.com/apppasswords
# ============================================================
CONTACT_EMAIL_1=your-email@gmail.com
CONTACT_EMAIL_2=your-other-email@gmail.com
SMTP_USER=your-email@gmail.com
SMTP_PASS=YOUR_GMAIL_APP_PASSWORD

# ============================================================
# Emulator (local dev only - always false in production)
# ============================================================
USE_EMULATOR=false
